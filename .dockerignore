test/
**/*.spec.ts
**/*.e2e-spec.ts
jest.config.js

# OS / editor artifacts
.DS_Store
Thumbs.db
.idea/
.vscode/

# Docker files (not needed inside the image)
Dockerfile*
docker-compose*.yml
.dockerignore
